# Required
OPENAI_API_KEY=replace_with_your_key

# Optional model settings
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://dimitriosmarkoulis.github.io,http://localhost:5500,http://127.0.0.1:5500

# Optional GitHub token for higher API limits when fetching public README files
GITHUB_TOKEN=

# Local vector index path
INDEX_PATH=data/project_vector_index.json
